{
  "name": "chat-service",
  "version": "1.0.0",
  "description": "",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc --project tsconfig.json && tsc-alias -p tsconfig.json --resolve-full-paths",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "lint": "eslint \"src/**/*.ts\" \"e2e/**/*.ts\"",
    "typecheck": "tsc --noEmit --project tsconfig.json",
    "test:unit": "vitest run --config vitest.config.ts src",
    "test:e2e": "vitest run --config vitest.config.ts e2e",
    "test": "npm run test:unit && npm run test:e2e",
    "format": "prettier --check \"src/**/*.ts\""
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@chatapp/common": "file:../../packages/common",
    "@grpc/grpc-js": "^1.13.4",
    "@grpc/proto-loader": "^0.7.15",
    "amqplib": "^0.10.9",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "helmet": "^8.1.0",
    "ioredis": "^5.8.2",
    "jsonwebtoken": "^9.0.2",
    "mongodb": "^7.0.0",
    "socket.io": "^4.8.1"
  },
  "devDependencies": {
    "@types/amqplib": "^0.10.8",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.5",
    "@types/helmet": "^4.0.0",
    "@types/supertest": "^6.0.3",
    "supertest": "^7.1.4",
    "tsc-alias": "^1.8.16",
    "typescript-eslint": "^8.48.0",
    "vitest": "^3.2.4"
  }
}
